```python
"""Print queue APSC — insert lệnh in HĐ APSC từ DLW vào print_queue.

Daemon trên laptop CN 100 LQĐ poll print_queue qua RPC get_next_print_job → in.
"""

from datetime import datetime
from zoneinfo import ZoneInfo

from utils.db import supabase
from utils.helpers import fmt_vnd  # hoặc adapt nếu DLW có helper riêng

_TZ_VN = ZoneInfo("Asia/Ho_Chi_Minh")

# ────────── CONSTANTS (copy từ POS) ──────────
LINE_WIDTH = 42
SEP_THIN  = "-" * LINE_WIDTH
SEP_THICK = "=" * LINE_WIDTH

PRINT_ENABLED_BRANCHES = {"100 Lê Quý Đôn"}

_CN_ADDR_SHORT = {
    "100 Lê Quý Đôn": "100 Lê Quý Đôn, Bà Rịa",
    "Coop Vũng Tàu":  "Coop Vũng Tàu - 36 Nguyễn Thái Học",
    "GO BÀ RỊA":      "Siêu thị GO, Bà Rịa",
}


# ────────── LAYOUT HELPERS (copy từ POS) ──────────
def _center(s: str, width: int = LINE_WIDTH) -> str:
    s = s.strip()
    if len(s) >= width:
        return s[:width]
    pad = (width - len(s)) // 2
    return " " * pad + s


def _two_cols(left: str, right: str, width: int = LINE_WIDTH) -> str:
    left = str(left)
    right = str(right)
    space = width - len(left) - len(right)
    if space < 1:
        left = left[: max(0, width - len(right) - 1)]
        space = width - len(left) - len(right)
    return left + " " * space + right


def _wrap(text: str, width: int = LINE_WIDTH) -> list:
    text = (text or "").strip()
    if not text:
        return [""]
    out = []
    line = ""
    for word in text.split():
        if not line:
            line = word
        elif len(line) + 1 + len(word) <= width:
            line += " " + word
        else:
            out.append(line)
            line = word
    if line:
        out.append(line)
    final = []
    for ln in out:
        while len(ln) > width:
            final.append(ln[:width])
            ln = ln[width:]
        final.append(ln)
    return final or [""]


def _header(chi_nhanh: str) -> list:
    addr = _CN_ADDR_SHORT.get(chi_nhanh, chi_nhanh)
    return [_center("DL Watch"), _center(addr)]


# ────────── LOADER ──────────
def _load_apsc_by_ma(ma_hd: str) -> dict | None:
    """Load HĐ APSC từ table hoa_don. Group N rows thành 1 dict.
    
    Returns:
        {
            'ma_hd': str,
            'chi_nhanh': str,
            'created_at_text': str (Thời gian tạo gốc),
            'nguoi_ban': str,
            'ten_khach': str,
            'sdt_khach': str,
            'ma_ycsc': str,
            'tong_tien_hang': int,
            'giam_gia_don': int,
            'khach_can_tra': int,
            'tien_mat': int,
            'chuyen_khoan': int,
            'the': int,
            'trang_thai': str,
            'ghi_chu': str,
            'items': [{ten_hang, ma_hang, so_luong, don_gia, thanh_tien, bao_hanh}, ...]
        }
    """
    res = (
        supabase.table("hoa_don")
        .select(
            '"Mã hóa đơn", "Chi nhánh", "Thời gian tạo", "Người bán", '
            '"Tên khách hàng", "Điện thoại", "Mã YCSC", '
            '"Tổng tiền hàng", "Giảm giá hóa đơn", "Khách cần trả", '
            '"Tiền mặt", "Chuyển khoản", "Thẻ", "Trạng thái", "Ghi chú", '
            '"Mã hàng", "Tên hàng", "Số lượng", "Đơn giá", "Thành tiền", "Bảo hành"'
        )
        .eq("Mã hóa đơn", ma_hd)
        .execute()
    )
    
    if not res.data:
        return None
    
    rows = res.data
    first = rows[0]
    
    # Header info from first row
    apsc = {
        "ma_hd": first["Mã hóa đơn"],
        "chi_nhanh": first.get("Chi nhánh", ""),
        "created_at_text": first.get("Thời gian tạo", ""),
        "nguoi_ban": first.get("Người bán", "") or "—",
        "ten_khach": first.get("Tên khách hàng", "") or "Khách lẻ",
        "sdt_khach": first.get("Điện thoại", ""),
        "ma_ycsc": first.get("Mã YCSC", "") or "",
        "tong_tien_hang": int(first.get("Tổng tiền hàng") or 0),
        "giam_gia_don": int(first.get("Giảm giá hóa đơn") or 0),
        "khach_can_tra": int(first.get("Khách cần trả") or 0),
        "tien_mat": int(first.get("Tiền mặt") or 0),
        "chuyen_khoan": int(first.get("Chuyển khoản") or 0),
        "the": int(first.get("Thẻ") or 0),
        "trang_thai": first.get("Trạng thái", ""),
        "ghi_chu": first.get("Ghi chú", "") or "",
        "items": [],
    }
    
    # Items from each row
    for row in rows:
        ten_hang = row.get("Tên hàng", "")
        if not ten_hang:
            continue
        apsc["items"].append({
            "ten_hang": ten_hang,
            "ma_hang": row.get("Mã hàng", ""),
            "so_luong": int(row.get("Số lượng") or 0),
            "don_gia": int(row.get("Đơn giá") or 0),
            "thanh_tien": int(row.get("Thành tiền") or 0),
            "bao_hanh": row.get("Bảo hành", "") or "",
        })
    
    return apsc


# ────────── BUILDER ──────────
def _build_text_apsc(apsc: dict) -> str:
    """Build text 42 chars cho HĐ APSC."""
    chi_nhanh = apsc.get("chi_nhanh", "")
    items = apsc.get("items", [])
    is_cancelled = apsc.get("trang_thai") == "Đã hủy"
    
    lines = []
    lines.extend(_header(chi_nhanh))
    lines.append(SEP_THICK)
    
    if is_cancelled:
        lines.append(_center("*** HÓA ĐƠN ĐÃ HỦY ***"))
        lines.append(SEP_THICK)
    
    lines.append("HÓA ĐƠN SỬA CHỮA")
    lines.append(_two_cols("Mã HĐ:", apsc.get("ma_hd", "")))
    lines.append(_two_cols("Ngày:", apsc.get("created_at_text", "")))
    lines.append(_two_cols("NV:", apsc.get("nguoi_ban", "—")))
    if apsc.get("ma_ycsc"):
        lines.append(_two_cols("Phiếu SC:", apsc["ma_ycsc"]))
    lines.append(SEP_THIN)
    
    lines.append(_two_cols("Khách:", apsc.get("ten_khach", "Khách lẻ")))
    if apsc.get("sdt_khach"):
        lines.append(_two_cols("SĐT:", apsc["sdt_khach"]))
    
    lines.append(SEP_THICK)
    lines.append("Dịch vụ / Linh kiện:")
    
    for ct in items:
        for w in _wrap(ct["ten_hang"]):
            lines.append("- " + w if w == _wrap(ct["ten_hang"])[0] else "  " + w)
        left = f"  {ct['so_luong']} x {fmt_vnd(ct['don_gia'])}"
        lines.append(_two_cols(left, fmt_vnd(ct["thanh_tien"])))
        if ct.get("bao_hanh"):
            lines.append(f"  BH: {ct['bao_hanh']}")
    
    lines.append(SEP_THIN)
    
    tong_hang = apsc.get("tong_tien_hang", 0)
    gg_don = apsc.get("giam_gia_don", 0)
    can_tra = apsc.get("khach_can_tra", 0)
    
    lines.append(_two_cols("Tổng tiền hàng:", fmt_vnd(tong_hang)))
    if gg_don > 0:
        lines.append(_two_cols("Giảm giá:", "-" + fmt_vnd(gg_don)))
    lines.append(_two_cols("Khách cần trả:", fmt_vnd(can_tra)))
    
    lines.append(SEP_THIN)
    
    tm = apsc.get("tien_mat", 0)
    ck = apsc.get("chuyen_khoan", 0)
    the = apsc.get("the", 0)
    if tm > 0:
        lines.append(_two_cols("Tiền mặt:", fmt_vnd(tm)))
    if ck > 0:
        lines.append(_two_cols("Chuyển khoản:", fmt_vnd(ck)))
    if the > 0:
        lines.append(_two_cols("Thẻ:", fmt_vnd(the)))
    
    lines.append(SEP_THICK)
    if is_cancelled:
        lines.append(_center("*** ĐÃ HỦY — CHỈ THAM KHẢO ***"))
    else:
        lines.append(_center("Cảm ơn quý khách!"))
    
    return "\n".join(lines)


# ────────── INSERT JOB ──────────
def _insert_print_job(doc_type: str, doc_id: str, chi_nhanh: str,
                      text: str, data: dict, created_by: str = "") -> dict:
    if not text or not text.strip():
        return {"ok": False, "error": "Nội dung in rỗng"}
    try:
        payload = {
            "text": text,
            "title": doc_id,
            "data": data or {},
        }
        row = {
            "doc_type":     doc_type,
            "doc_id":       doc_id,
            "chi_nhanh":    chi_nhanh,
            "payload_json": payload,
            "created_by":   created_by or "",
            "source_app":   "dlw_app",  # ← distinguish với POS
        }
        res = supabase.table("print_queue").insert(row).execute()
        if res.data:
            return {"ok": True, "id": res.data[0].get("id")}
        return {"ok": False, "error": "Insert không trả về data"}
    except Exception as e:
        return {"ok": False, "error": str(e)}


# ────────── PUBLIC API ──────────
def enqueue_apsc(ma_hd: str, created_by: str = "") -> dict:
    """Enqueue lệnh in HĐ APSC. Trả về {ok, id?, error?}."""
    if not ma_hd:
        return {"ok": False, "error": "Thiếu mã HĐ"}
    if not ma_hd.startswith("APSC"):
        return {"ok": False, "error": "Mã HĐ phải bắt đầu bằng APSC"}
    
    apsc = _load_apsc_by_ma(ma_hd)
    if not apsc:
        return {"ok": False, "error": f"Không tìm thấy HĐ {ma_hd}"}
    
    chi_nhanh = apsc.get("chi_nhanh", "")
    if chi_nhanh not in PRINT_ENABLED_BRANCHES:
        return {"ok": False, "error": "Chi nhánh chưa có máy in"}
    
    text = _build_text_apsc(apsc)
    return _insert_print_job(
        doc_type="hoa_don_sua_chua",
        doc_id=ma_hd,
        chi_nhanh=chi_nhanh,
        text=text,
        data={"ma_hd": ma_hd, "ma_ycsc": apsc.get("ma_ycsc", "")},
        created_by=created_by,
    )


def call_huy_hoa_don_apsc(ma_hd: str, cancelled_by: str) -> dict:
    """Gọi RPC huy_hoa_don_apsc từ Python. Trả về {ok, error?, items_count?, kho_restored?}."""
    try:
        res = supabase.rpc("huy_hoa_don_apsc", {
            "p_ma_hd": ma_hd,
            "p_cancelled_by": cancelled_by
        }).execute()
        return res.data or {"ok": False, "error": "RPC không trả về data"}
    except Exception as e:
        return {"ok": False, "error": str(e)}
