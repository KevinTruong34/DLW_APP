    confirm_text = st.text_input(
        "Gõ **HỦY** để xác nhận:",
        key=f"cancel_confirm_text_{apsc['ma_hd']}"
    )
    
    col1, col2 = st.columns(2)
    with col1:
        if st.button("✅ Xác nhận hủy", 
                      disabled=confirm_text.strip().upper() != "HỦY",
                      type="primary",
                      key=f"cancel_submit_{apsc['ma_hd']}"):
            from utils.print_queue_apsc import call_huy_hoa_don_apsc
            result = call_huy_hoa_don_apsc(apsc["ma_hd"], get_user()["ho_ten"])
            if result.get("ok"):
                st.success(f"✅ Đã hủy {apsc['ma_hd']} — kho cộng lại {result.get('kho_restored', 0)} items")
                st.session_state.pop("confirm_cancel_apsc", None)
                st.rerun()
            else:
                st.error(f"❌ {result.get('error')}")
    with col2:
        if st.button("Quay lại", key=f"cancel_back_{apsc['ma_hd']}"):
            st.session_state.pop("confirm_cancel_apsc", None)
            st.rerun()
