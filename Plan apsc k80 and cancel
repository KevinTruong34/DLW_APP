## 3. PHASE 2 — RPC `huy_hoa_don_apsc`

### 3.1 Logic

1. Validate input (ma_hd start với 'APSC', cancelled_by không rỗng)
2. Lookup HĐ — nếu không tồn tại / đã hủy → return error
3. **Đảo kho atomic:** với mỗi item có `Mã hàng` không phải open-price → `UPDATE the_kho SET "Tồn cuối kì" += so_luong WHERE "Mã hàng" = ... AND "Chi nhánh" = ...`
4. Set `"Trạng thái" = 'Đã hủy'` cho TẤT CẢ rows của HĐ
5. Audit log `ADMIN_APSC_CANCEL` vào `action_logs`

```sql
CREATE OR REPLACE FUNCTION huy_hoa_don_apsc(
    p_ma_hd text,
    p_cancelled_by text
)
RETURNS jsonb
LANGUAGE plpgsql
AS $$
DECLARE
    v_chi_nhanh text;
    v_trang_thai text;
    v_item RECORD;
    v_count_items int := 0;
    v_count_kho int := 0;
BEGIN
    -- 1. Validate
    IF p_ma_hd IS NULL OR p_ma_hd = '' OR LEFT(p_ma_hd, 4) != 'APSC' THEN
        RETURN jsonb_build_object('ok', false, 'error', 'Mã HĐ APSC không hợp lệ');
    END IF;
    
    IF p_cancelled_by IS NULL OR p_cancelled_by = '' THEN
        RETURN jsonb_build_object('ok', false, 'error', 'Thiếu cancelled_by');
    END IF;
    
    -- 2. Lookup (lấy chi_nhanh + trạng thái từ row đầu)
    SELECT "Chi nhánh", "Trạng thái" INTO v_chi_nhanh, v_trang_thai
    FROM hoa_don
    WHERE "Mã hóa đơn" = p_ma_hd
    LIMIT 1
    FOR UPDATE;
    
    IF v_chi_nhanh IS NULL THEN
        RETURN jsonb_build_object('ok', false, 'error', 'HĐ không tồn tại');
    END IF;
    
    IF v_trang_thai = 'Đã hủy' THEN
        RETURN jsonb_build_object('ok', false, 'error', 'HĐ đã bị hủy trước đó');
    END IF;
    
    -- 3. Đảo kho atomic — bypass open-price
    FOR v_item IN 
        SELECT "Mã hàng", "Số lượng"
        FROM hoa_don
        WHERE "Mã hóa đơn" = p_ma_hd 
          AND "Mã hàng" IS NOT NULL 
          AND "Mã hàng" != ''
    LOOP
        v_count_items := v_count_items + 1;
        
        IF NOT is_open_price_sql(v_item."Mã hàng") THEN
            UPDATE the_kho 
            SET "Tồn cuối kì" = COALESCE("Tồn cuối kì", 0) + v_item."Số lượng"
            WHERE "Mã hàng" = v_item."Mã hàng" 
              AND "Chi nhánh" = v_chi_nhanh;
            
            IF FOUND THEN
                v_count_kho := v_count_kho + 1;
            ELSE
                -- Insert dòng mới the_kho nếu chưa có
                INSERT INTO the_kho ("Mã hàng", "Chi nhánh", "Tồn cuối kì")
                VALUES (v_item."Mã hàng", v_chi_nhanh, v_item."Số lượng");
                v_count_kho := v_count_kho + 1;
            END IF;
        END IF;
    END LOOP;
    
    -- 4. Set trạng thái = 'Đã hủy' cho TẤT CẢ rows
    UPDATE hoa_don
    SET "Trạng thái" = 'Đã hủy',
        "Ngày cập nhật" = to_char(now() AT TIME ZONE 'Asia/Ho_Chi_Minh', 'YYYY-MM-DD HH24:MI:SS')
    WHERE "Mã hóa đơn" = p_ma_hd;
    
    -- 5. Audit log
    INSERT INTO action_logs (username, ho_ten, chi_nhanh, action, detail, level)
    VALUES (
        p_cancelled_by,
        p_cancelled_by,
        v_chi_nhanh,
        'ADMIN_APSC_CANCEL',
        format('ma=%s items=%s kho_restored=%s', 
               p_ma_hd, v_count_items, v_count_kho),
        'warn'
    );
    
    RETURN jsonb_build_object(
        'ok', true,
        'ma_hd', p_ma_hd,
        'items_count', v_count_items,
        'kho_restored', v_count_kho
    );
END;
$$;
```

