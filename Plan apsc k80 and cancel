def _render_confirm_cancel_apsc(apsc: dict):
    st.markdown(f"### ⚠️ Xác nhận hủy HĐ {apsc['ma_hd']}")
    st.markdown(f"**Tổng tiền:** {fmt_vnd(apsc['khach_can_tra'])}")
