```python
def search_hd_pos_for_edit(
    chi_nhanh: str | None = None,
    ngay_tu: str | None = None,
    ngay_den: str | None = None,
    nguoi_ban_id: int | None = None,
    ma_hd_search: str | None = None,
    limit: int = 50
) -> list[dict]:
    """Tìm HĐ POS để admin chọn sửa. Chỉ trả về HĐ trang_thai='Hoàn thành'."""
    query = (
        supabase.table("hoa_don_pos")
        .select("ma_hd, chi_nhanh, created_at, nguoi_ban, nguoi_ban_id, "
                "khach_can_tra, ten_khach, trang_thai, is_admin_created")
        .eq("trang_thai", "Hoàn thành")
        .order("created_at", desc=True)
        .limit(limit)
    )
    if chi_nhanh:
        query = query.eq("chi_nhanh", chi_nhanh)
    if ngay_tu:
        query = query.gte("created_at", ngay_tu)
    if ngay_den:
        query = query.lte("created_at", ngay_den)
    if nguoi_ban_id:
        query = query.eq("nguoi_ban_id", nguoi_ban_id)
    if ma_hd_search:
        query = query.ilike("ma_hd", f"%{ma_hd_search}%")
    
    res = query.execute()
    return res.data or []


def load_hd_with_edit_history(ma_hd: str) -> dict:
    """Load HĐ + items + edit history qua RPC."""
    res = supabase.rpc("load_hd_pos_with_history", {"p_ma_hd": ma_hd}).execute()
    return res.data or {}
```

